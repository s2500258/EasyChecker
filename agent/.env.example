# Copy this file to agent/.env on the target machine.
# Use EVENT_SOURCE=sample for a safe connectivity test first.
# Switch to EVENT_SOURCE=windows when testing the live Windows collector.
BACKEND_URL=http://127.0.0.1:8000/api/v1/ingest
POLL_INTERVAL=5
HOSTNAME=WIN-PC-01
OS_TYPE=windows
EVENT_SOURCE=sample
MAX_EVENTS_PER_CYCLE=5
RUN_ONCE=true
COLLECT_LOGIN_EVENTS=true
COLLECT_PROCESS_EVENTS=true
COLLECT_SERVICE_EVENTS=true
PROCESS_NAME_ALLOWLIST=
SERVICE_NAME_ALLOWLIST=
